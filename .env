# SMS Gateway Configuration
# For real SMS, configure one of the providers below:

# Option 1: Fast2SMS (Free for India)
# Get free API key from https://www.fast2sms.com/
# Then uncomment and fill:
# SMS_PROVIDER=fast2sms
# FAST2SMS_API_KEY=your_api_key_here

# Option 2: Twilio (Paid - Works globally)
# Get credentials from https://www.twilio.com/
# Then uncomment and fill:
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Currently using demo mode (no real SMS)
SMS_PROVIDER=demo

# Flask Configuration
FLASK_SECRET_KEY=safeguard-secret-key-change-in-production
FLASK_ENV=development
